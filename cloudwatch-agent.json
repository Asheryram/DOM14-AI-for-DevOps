{
  "agent": {
    "metrics_collection_interval": 15,
    "run_as_user": "root"
  },
  "metrics": {
    "namespace": "TechStream/GoldenSignals",
    "metrics_collected": {
      "cpu": {
        "measurement": ["cpu_usage_idle","cpu_usage_iowait"],
        "metrics_collection_interval": 15,
        "totalcpu": true
      }
    }
  }
}
