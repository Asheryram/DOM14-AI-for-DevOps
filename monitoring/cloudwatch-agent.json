{
  "agent": {
    "metrics_collection_interval": 15,
    "run_as_user": "root"
  },
  "metrics": {
    "namespace": "TechStream/GoldenSignals",
    "metrics_collected": {
      "cpu": {
        "measurement": ["cpu_usage_idle", "cpu_usage_iowait", "cpu_usage_user", "cpu_usage_system"],
        "metrics_collection_interval": 15,
        "totalcpu": true
      },
      "mem": {
        "measurement": ["mem_used_percent", "mem_available_percent"],
        "metrics_collection_interval": 15
      },
      "disk": {
        "measurement": ["disk_used_percent", "disk_inodes_free"],
        "metrics_collection_interval": 60,
        "resources": ["/"]
      },
      "net": {
        "measurement": ["net_bytes_recv", "net_bytes_sent", "net_drop_in", "net_drop_out"],
        "metrics_collection_interval": 15,
        "resources": ["eth0", "ens5"]
      }
    },
    "append_dimensions": {
      "AutoScalingGroupName": "${aws:AutoScalingGroupName}",
      "InstanceId": "${aws:InstanceId}"
    }
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/flask-app/error.log",
            "log_group_name": "/techstream/flask-app",
            "log_stream_name": "{instance_id}/error",
            "timezone": "UTC"
          }
        ]
      }
    }
  }
}
