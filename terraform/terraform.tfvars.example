# Copy this file to terraform.tfvars and fill in the values marked REQUIRED.
# terraform.tfvars is gitignored — never commit it.

# ── Region / environment ──────────────────────────────────────────────────────
aws_region  = "eu-west-1"
environment = "prod"

# ── Networking (Terraform creates the VPC and all subnets automatically) ──────
vpc_cidr = "10.0.0.0/16"   # change only if this range conflicts with existing VPCs

# ── Compute ───────────────────────────────────────────────────────────────────
instance_type = "t3.medium"
key_name      = ""          # set to an existing EC2 key pair name to enable SSH

# ── Auto Scaling capacity ─────────────────────────────────────────────────────
asg_min_size         = 2
asg_max_size         = 10
asg_desired_capacity = 2

# ── Notification addresses ────────────────────────────────────────────────────
oncall_email    = "oncall@techstream.io"
incidents_email = "incidents@techstream.io"
ses_from_email  = "devops-guru@techstream.io"   # must be verified in SES

# ── Bedrock model for RCA ─────────────────────────────────────────────────────
bedrock_model_id = "anthropic.claude-sonnet-4-6"

# ── DevOps Guru ───────────────────────────────────────────────────────────────
cloudformation_stack_name = "TechStream-Prod"

# ── Grafana — REQUIRED ────────────────────────────────────────────────────────
grafana_admin_password = "change-me-before-apply"
